<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Releasea Static Site</title>
    <style>
      :root {
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
        color: #0f172a;
        background: #f8fafc;
      }
      body { margin: 0; }
      main {
        min-height: 100vh;
        display: grid;
        place-content: center;
        gap: 0.75rem;
        padding: 1.5rem;
        text-align: center;
      }
      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
      }
      p { margin: 0; color: #334155; }
    </style>
  </head>
  <body>
    <main>
      <h1>Releasea Static Site</h1>
      <p>This is a minimal 11ty template ready for Releasea static deployments.</p>
    </main>
  </body>
</html>
